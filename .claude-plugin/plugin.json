{
  "name": "agent-bridge",
  "version": "0.3.0",
  "description": "Delegate tasks to external AI CLI agents (Codex, Gemini, and more)",
  "author": {
    "name": "Kira-Pgr",
    "url": "https://github.com/Kira-Pgr"
  },
  "repository": "https://github.com/Kira-Pgr/agent-bridge",
  "license": "MIT",
  "agents": [
    "./agents/codex.md",
    "./agents/gemini.md"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-context.sh"
          }
        ]
      }
    ]
  }
}
